# OpenRouter (recomendado): PROVIDER=openrouter y MODEL = slug de OpenRouter,
# ej. moonshotai/kimi-k2.6 (multi-agente, tool-calling, rápido) o anthropic/claude-sonnet-4.6.
# Anthropic nativo: PROVIDER=anthropic y MODEL = ID de Anthropic, ej. claude-sonnet-4-6.
PROVIDER=openrouter
MODEL=moonshotai/kimi-k2.6
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
# Token del SIE de Banxico para datos macro en vivo (gratis en banxico.org.mx/SieAPIRest/service/v1/token)
BANXICO_TOKEN=
DATABASE_URL=sqlite:///./banxico.db
CORS_ORIGINS=http://localhost:5173
# Generar con: openssl rand -hex 32
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_HOURS=720
ALLOW_REGISTRATION=true
# Modo demo público ($0): la Simulación de Junta reproduce debates pre-generados
# (app/data/demo_meetings/) SIN llamar al LLM, y el chat 1-a-1 se deshabilita.
# No requiere ninguna API key. Ponlo en true para un deploy público sin costo.
DEMO_MODE=false
